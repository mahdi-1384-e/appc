<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appc.MainPage"
             BackgroundColor="#121212">
    <VerticalStackLayout VerticalOptions="Center" Padding="30" Spacing="20">
        <Label Text="Service Status" FontSize="24" HorizontalOptions="Center" TextColor="White"/>
        <Frame BackgroundColor="#1E1E1E" CornerRadius="10">
            <Label x:Name="CfgLabel" FontSize="16" TextColor="#00FF00" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
        </Frame>
    </VerticalStackLayout>
</ContentPage>